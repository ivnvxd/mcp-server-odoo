# Odoo MCP Server Configuration
# Copy this file to .env and update with your instance details
#
# For production remote deployment, you MUST configure:
# 1. Odoo connection (ODOO_URL + auth)
# 2. MCP client authentication (ODOO_MCP_AUTH_MODE)
# 3. Model allowlist (ODOO_ALLOWED_MODELS)

# ============================================================
# Odoo Connection
# ============================================================

# Odoo server URL (required)
ODOO_URL=http://localhost:8069

# Database name (optional — auto-detected if not set)
# ODOO_DB=your-database-name

# ============================================================
# Odoo Authentication (to Odoo instance)
# ============================================================

# Method 1: API key (preferred)
# Generate in Odoo: Settings > Users & Companies > Users > API Keys
ODOO_API_KEY=your-odoo-api-key-here

# Method 2: Username/password (fallback, used if no API key)
# ODOO_USER=your-username
# ODOO_PASSWORD=your-password

# ============================================================
# YOLO Mode (Development/Testing Only!)
# ============================================================

# Bypasses MCP module — connects directly to standard XML-RPC endpoints
# Valid values: off (default), read (read-only), true (full CRUD)
# WARNING: Do not use YOLO mode in production without safety guardrails
# ODOO_YOLO=off

# ============================================================
# MCP Client Authentication
# ============================================================

# Auth mode for MCP clients connecting to this server
# Valid values: none, api_key, oauth2
# Default: none (only safe for local stdio transport!)
ODOO_MCP_AUTH_MODE=none

# --- API Key Auth ---
# Comma-separated API keys that MCP clients must provide in X-API-Key header
# Required when ODOO_MCP_AUTH_MODE=api_key
# ODOO_MCP_API_KEYS=key1,key2

# --- OAuth 2.0 Auth ---
# Required when ODOO_MCP_AUTH_MODE=oauth2
# ODOO_MCP_OAUTH2_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
# ODOO_MCP_OAUTH2_AUDIENCE=api://your-app-id
# ODOO_MCP_OAUTH2_JWKS_URL=https://login.microsoftonline.com/{tenant-id}/discovery/v2.0/keys
# ODOO_MCP_OAUTH2_CLIENT_ID=your-client-id
# ODOO_MCP_OAUTH2_CLIENT_SECRET=your-client-secret
# ODOO_MCP_OAUTH2_SCOPES=odoo.read,odoo.write

# ============================================================
# Safety Guardrails (Security Policy)
# ============================================================

# Comma-separated list of allowed Odoo models
# REQUIRED when auth is enabled (fail-safe default)
# Example: res.partner,res.company,sale.order,project.task
# ODOO_ALLOWED_MODELS=res.partner,res.company

# Allowed read operations (default: search_read,read,fields_get,search_count)
# ODOO_ALLOWED_READ_OPERATIONS=search_read,read,fields_get,search_count

# Allowed write operations (default: create,write)
# ODOO_ALLOWED_WRITE_OPERATIONS=create,write

# Per-model operation map (JSON, overrides global lists)
# ODOO_MODEL_OPERATION_MAP={"res.partner":["read","create"],"sale.order":["read"]}

# Field-level allowlists (per model, dots→underscores)
# Only these fields will be readable/writable
# ODOO_FIELD_ALLOWLIST_RES_PARTNER=name,email,phone,company_id,street,city,country_id
# ODOO_FIELD_ALLOWLIST_SALE_ORDER=name,state,partner_id,amount_total,date_order

# Field-level denylists (per model, dots→underscores)
# These fields will be hidden/stripped
# ODOO_FIELD_DENYLIST_RES_PARTNER=password_crypt,oauth_access_token

# Maximum records per query (default: 100)
# ODOO_MAX_RECORDS_PER_QUERY=100

# Maximum batch size for bulk operations (default: 50)
# ODOO_MAX_BATCH_SIZE=50

# Enable write operations (default: false — read-only by default!)
# ODOO_ENABLE_MUTATIONS=false

# Enable delete operations (default: false, requires ENABLE_MUTATIONS=true)
# ODOO_ENABLE_DELETES=false

# Require confirmation token for mutations (default: true)
# When true, write tools return a confirmation token that must be sent back
# ODOO_REQUIRE_CONFIRMATION_FOR_MUTATIONS=true

# ============================================================
# CORS Configuration
# ============================================================

# Allowed CORS origins (comma-separated)
# Set to * for all origins (not recommended for production)
# ODOO_MCP_CORS_ORIGINS=https://chat.openai.com,https://copilot.microsoft.com

# Allow credentials in CORS (default: false)
# ODOO_MCP_CORS_CREDENTIALS=false

# ============================================================
# Audit Logging
# ============================================================

# Enable structured audit logging for all tool calls (default: true)
# ODOO_MCP_AUDIT_LOG=true

# ============================================================
# Admin Mode (DANGEROUS — disabled by default)
# ============================================================

# Bypasses ALL security policy checks (model allowlist, field filtering,
# mutation controls). Only for trusted internal admin scenarios.
# ODOO_MCP_ADMIN_MODE=false

# ============================================================
# Transport Configuration
# ============================================================

# Transport type: stdio (default) or streamable-http
ODOO_MCP_TRANSPORT=stdio

# Server host for HTTP transport (use 0.0.0.0 for Docker)
# ODOO_MCP_HOST=localhost

# Server port for HTTP transport
# ODOO_MCP_PORT=8000

# ============================================================
# Logging Configuration
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ODOO_MCP_LOG_LEVEL=INFO

# Structured JSON log output (recommended for production)
# ODOO_MCP_LOG_JSON=false

# Path for rotating log file (10 MB, 5 backups)
# ODOO_MCP_LOG_FILE=/var/log/mcp-server-odoo.log

# ============================================================
# Locale Configuration
# ============================================================

# Language/locale for Odoo responses (optional)
# ODOO_LOCALE=en_US

# ============================================================
# Performance Configuration
# ============================================================

# Default pagination limit (default: 10)
# ODOO_MCP_DEFAULT_LIMIT=10

# Maximum pagination limit (default: 100)
# ODOO_MCP_MAX_LIMIT=100

# Maximum fields returned by smart field selection (default: 15)
# ODOO_MCP_MAX_SMART_FIELDS=15
